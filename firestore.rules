rules_version = '2';

// v1 assumption: orgId == the owning user's Firebase Auth uid (see CLAUDE.md,
// "Data model" — there is no separate members lookup yet, so this only
// covers the owner. Revisit when team member invites are built.
service cloud.firestore {
  match /databases/{database}/documents {
    match /organizations/{orgId} {
      allow read, write: if request.auth != null && request.auth.uid == orgId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == orgId;
      }
    }
  }
}
